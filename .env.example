# Google Cloud Configuration
GOOGLE_CLOUD_PROJECT=your-google-cloud-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# Gemini API Configuration
# Set GOOGLE_GENAI_USE_VERTEXAI to "True" to use Vertex AI, "False" to use Gemini Developer API (AI Studio)
GOOGLE_GENAI_USE_VERTEXAI="False"

# Required if GOOGLE_GENAI_USE_VERTEXAI="False"
GOOGLE_API_KEY="your-gemini-api-key-here"

# MCP Tool Server
MCP_SERVER_URL=http://0.0.0.0:8080/mcp

# Agent Card URLs (Usually set automatically by run-locally.sh)
THIRD_PARTY_AGENT_CARD_URL=http://localhost:8081/.well-known/agent-card.json
CORROSION_AGENT_CARD_URL=http://localhost:8082/.well-known/agent-card.json
CONSOLIDATOR_AGENT_CARD_URL=http://localhost:8083/.well-known/agent-card.json
